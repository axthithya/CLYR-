<UserControl
    x:Class="Clyr.App.Controls.EmptyState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AutomationProperties.Name="{x:Bind Title, Mode=OneWay}">
    <Border Style="{StaticResource StandardCardStyle}" Padding="32">
        <StackPanel Spacing="12" HorizontalAlignment="Center" MaxWidth="560">
            <FontIcon Glyph="{x:Bind Glyph, Mode=OneWay}" FontSize="30" Foreground="{ThemeResource AccentPrimary}" HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind Title, Mode=OneWay}" Style="{StaticResource SectionTitleStyle}" TextAlignment="Center" />
            <TextBlock Text="{x:Bind Message, Mode=OneWay}" Style="{StaticResource BodySecondaryStyle}" TextAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
