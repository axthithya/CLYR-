<UserControl
    x:Class="Clyr.App.Controls.EmptyState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardStyle}" Padding="32">
        <StackPanel Spacing="10" HorizontalAlignment="Center" MaxWidth="560">
            <FontIcon Glyph="{x:Bind Glyph, Mode=OneWay}" FontSize="30" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" />
            <TextBlock Text="{x:Bind Message, Mode=OneWay}" Style="{StaticResource BodyMutedStyle}" TextAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
