<UserControl
    x:Class="Clyr.App.Controls.LoadingState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AutomationProperties.LiveSetting="Polite"
    AutomationProperties.Name="{x:Bind Title, Mode=OneWay}">
    <Border Style="{StaticResource CompactCardStyle}">
        <StackPanel HorizontalAlignment="Center" Spacing="12">
            <ProgressRing
                Width="32"
                Height="32"
                HorizontalAlignment="Center"
                IsActive="{x:Bind IsActive, Mode=OneWay}" />
            <TextBlock
                Style="{StaticResource CardTitleStyle}"
                Text="{x:Bind Title, Mode=OneWay}"
                TextAlignment="Center" />
            <TextBlock
                MaxWidth="560"
                Style="{StaticResource BodySecondaryStyle}"
                Text="{x:Bind Message, Mode=OneWay}"
                TextAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
