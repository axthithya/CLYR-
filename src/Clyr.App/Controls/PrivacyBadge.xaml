<UserControl
    x:Class="Clyr.App.Controls.PrivacyBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AutomationProperties.Name="Private Local Read-only trust badge">
    <Border Style="{StaticResource PrivacyBadgeStyle}">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon
                FontSize="{StaticResource IconSizeSmall}"
                Foreground="{ThemeResource PrivacySafe}"
                Glyph="&#xE72E;" />
            <TextBlock
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextSecondary}"
                Text="Private · Local · Read-only" />
        </StackPanel>
    </Border>
</UserControl>
