<UserControl
    x:Class="Clyr.App.Controls.SectionHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid ColumnSpacing="16" AutomationProperties.Name="{x:Bind Title, Mode=OneWay}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel MinWidth="0" Spacing="4">
            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{x:Bind Title, Mode=OneWay}" />
            <TextBlock Style="{StaticResource BodySecondaryStyle}" Text="{x:Bind Description, Mode=OneWay}" />
        </StackPanel>
        <ContentPresenter
            Grid.Column="1"
            VerticalAlignment="Top"
            Content="{x:Bind ActionContent, Mode=OneWay}" />
    </Grid>
</UserControl>
