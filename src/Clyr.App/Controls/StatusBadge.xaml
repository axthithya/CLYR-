<UserControl
    x:Class="Clyr.App.Controls.StatusBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AutomationProperties.Name="{x:Bind Text, Mode=OneWay}">
    <Border Style="{StaticResource StatusBadgeStyle}">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon
                FontSize="{StaticResource IconSizeSmall}"
                Glyph="{x:Bind Glyph, Mode=OneWay}"
                IsHitTestVisible="False"
                AutomationProperties.AccessibilityView="Raw" />
            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{x:Bind Text, Mode=OneWay}"
                       AutomationProperties.AccessibilityView="Raw" />
        </StackPanel>
    </Border>
</UserControl>
