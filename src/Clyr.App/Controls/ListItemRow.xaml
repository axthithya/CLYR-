<UserControl
    x:Class="Clyr.App.Controls.ListItemRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MinHeight="48" Padding="4,8" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <FontIcon
            Width="24"
            VerticalAlignment="Center"
            FontSize="{StaticResource IconSizeStandard}"
            Foreground="{ThemeResource TextSecondary}"
            Glyph="{x:Bind Glyph, Mode=OneWay}"
            AutomationProperties.AccessibilityView="Raw" />
        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Style="{StaticResource BodyStyle}" Text="{x:Bind Title, Mode=OneWay}" />
            <TextBlock Style="{StaticResource CaptionStyle}" Text="{x:Bind Detail, Mode=OneWay}" />
        </StackPanel>
        <TextBlock
            Grid.Column="2"
            VerticalAlignment="Center"
            Style="{StaticResource BodySecondaryStyle}"
            Text="{x:Bind TrailingText, Mode=OneWay}" />
    </Grid>
</UserControl>
