<Page
    x:Class="Clyr.App.Pages.ScanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Background="{ThemeResource AppBackground}"
    AutomationProperties.Name="Scan page">
    <controls:ResponsivePageHost
        x:Name="PageHost"
        Title="Analyze a drive"
        Subtitle="See what is using storage without changing your files."
        AutomationProperties.Name="Scan responsive page host">
        <controls:ResponsivePageHost.PageContent>
            <StackPanel x:Name="ScanContent" Spacing="20">
                <StackPanel x:Name="SetupPanel" Spacing="18">
                    <Border x:Name="DrivePanel" Padding="20" Background="{ThemeResource SurfacePrimary}"
                            BorderBrush="{ThemeResource BorderSubtle}" BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusLargeSurface}"
                            AutomationProperties.Name="Selected local drive">
                        <StackPanel Spacing="14">
                            <Grid x:Name="DriveHeader" ColumnSpacing="20" RowSpacing="10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel MinWidth="0" Spacing="3">
                                    <TextBlock x:Name="DriveIdentity" Style="{StaticResource SectionTitleStyle}"
                                               TextTrimming="CharacterEllipsis" AutomationProperties.HeadingLevel="Level2" />
                                    <TextBlock x:Name="DriveTechnicalSummary" Style="{StaticResource CaptionStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock x:Name="DriveUsedPercentage" Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Right" />
                                    <TextBlock Text="used" Style="{StaticResource MetricLabelStyle}" HorizontalAlignment="Right" />
                                </StackPanel>
                                <ComboBox x:Name="DriveSelector" Grid.Row="1" Grid.ColumnSpan="2"
                                          HorizontalAlignment="Stretch" SelectionChanged="DriveChanged"
                                          AutomationProperties.Name="Local volume selector"
                                          AutomationProperties.HelpText="Choose the local drive to analyze." />
                            </Grid>
                            <Grid x:Name="DriveStorageBar" Height="16" Background="{ThemeResource SurfaceSecondary}"
                                  CornerRadius="8" AutomationProperties.Name="Selected drive storage usage">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="DriveUsedColumn" Width="0*" />
                                    <ColumnDefinition x:Name="DriveFreeColumn" Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="DriveUsedSegment" Background="{ThemeResource AccentPrimary}" CornerRadius="8,0,0,8" />
                            </Grid>
                            <Grid x:Name="DriveMetrics" ColumnSpacing="24" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel x:Name="DriveUsedMetric" Spacing="2">
                                    <TextBlock Text="Used storage" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock x:Name="DriveUsedValue" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="DriveFreeMetric" Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Free storage" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock x:Name="DriveFreeValue" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="DriveTotalMetric" Grid.Column="2" Spacing="2">
                                    <TextBlock Text="Total capacity" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock x:Name="DriveTotalValue" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="DriveReadyMetric" Grid.Column="3" Spacing="2">
                                    <TextBlock Text="Metadata scan" Style="{StaticResource MetricLabelStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon x:Name="DriveReadyIcon" Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource Success}" />
                                        <TextBlock x:Name="DriveReadyValue" Style="{StaticResource StatusTextStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <StackPanel x:Name="IdleActionPanel" Spacing="8">
                        <Button x:Name="StartButton" Content="Analyze drive" Style="{StaticResource PrimaryActionStyle}"
                                Click="StartAnalysis" HorizontalAlignment="Left"
                                AutomationProperties.Name="Analyze drive"
                                AutomationProperties.HelpText="Begins a private, read-only analysis of the selected drive." />
                        <TextBlock Text="CLYR analyzes the drive in the background and shows a live summary while it works."
                                   Style="{StaticResource BodyMutedStyle}" TextWrapping="Wrap" />
                        <StackPanel x:Name="SafetyNote" Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="{ThemeResource PrivacySafe}" />
                            <TextBlock Text="Reads file and folder metadata only. No files are changed."
                                       Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <Border x:Name="RunningPanel" Padding="24" Background="{ThemeResource SurfacePrimary}"
                        BorderBrush="{ThemeResource BorderSubtle}" BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusLargeSurface}" Visibility="Collapsed"
                        AutomationProperties.Name="Active analysis progress">
                    <Border.Transitions>
                        <TransitionCollection><EntranceThemeTransition FromVerticalOffset="8" /></TransitionCollection>
                    </Border.Transitions>
                    <StackPanel Spacing="20">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" Background="{ThemeResource SurfaceSelected}" CornerRadius="22">
                                <FontIcon Glyph="&#xE895;" FontSize="20" Foreground="{ThemeResource AccentPrimary}" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock x:Name="RunningTitle" Style="{StaticResource SectionTitleStyle}"
                                           AutomationProperties.HeadingLevel="Level2" AutomationProperties.LiveSetting="Polite" />
                                <TextBlock x:Name="RunningStatus" Style="{StaticResource BodySecondaryStyle}" />
                            </StackPanel>
                        </Grid>
                        <ProgressBar x:Name="ActiveProgress" IsIndeterminate="True" Height="5" HorizontalAlignment="Stretch"
                                     AutomationProperties.Name="Analysis in progress" />
                        <Grid x:Name="RunningMetrics" ColumnSpacing="20" RowSpacing="16">
                            <StackPanel x:Name="ElapsedMetric" Spacing="2">
                                <TextBlock Text="Time elapsed" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ElapsedText" Text="--" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="ObservedMetric" Spacing="2">
                                <TextBlock Text="Storage found so far" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ObservedSize" Text="--" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="FilesMetric" Spacing="2">
                                <TextBlock Text="Files checked" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="FileCount" Text="--" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="DirectoryMetric" Spacing="2">
                                <TextBlock Text="Folders checked" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="DirectoryCount" Text="--" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="WarningMetric" Spacing="2">
                                <TextBlock Text="Access issues" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="WarningCountText" Text="--" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                        </Grid>
                        <StackPanel x:Name="RunningActions" Orientation="Horizontal" Spacing="12">
                            <Button x:Name="StopButton" Content="Stop analysis" Click="StopAnalysis"
                                    Style="{StaticResource QuietButtonStyle}"
                                    AutomationProperties.Name="Stop analysis"
                                    AutomationProperties.HelpText="Stops the active analysis safely after the current metadata operation." />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="TerminalPanel" Spacing="20" Visibility="Collapsed"
                            AutomationProperties.Name="Analysis outcome">
                    <StackPanel.Transitions>
                        <TransitionCollection><EntranceThemeTransition FromVerticalOffset="8" /></TransitionCollection>
                    </StackPanel.Transitions>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border x:Name="TerminalIconSurface" Width="44" Height="44"
                                Background="{ThemeResource SuccessSurface}" CornerRadius="22">
                            <FontIcon x:Name="TerminalIcon" Glyph="&#xE73E;" FontSize="20" Foreground="{ThemeResource Success}" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock x:Name="TerminalTitle" Style="{StaticResource SectionTitleStyle}"
                                       AutomationProperties.HeadingLevel="Level2" AutomationProperties.LiveSetting="Polite" />
                            <TextBlock x:Name="TerminalMessage" Style="{StaticResource BodySecondaryStyle}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel x:Name="TerminalSummary" Spacing="16">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock x:Name="TerminalCoverageSentence" Style="{StaticResource CardTitleStyle}" TextWrapping="Wrap" />
                            <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}">
                                <TextBlock x:Name="QualityText" Style="{StaticResource StatusTextStyle}"
                                           AutomationProperties.Name="Scan coverage quality" AutomationProperties.LiveSetting="Polite" />
                            </Border>
                        </Grid>
                        <Grid x:Name="TerminalCoverage" ColumnSpacing="28" RowSpacing="18">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="4*" /><ColumnDefinition Width="3*" /></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="AccountedValue" FontSize="36" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimary}" />
                                <TextBlock x:Name="AccountedValueCaption" Text="coverage" Style="{StaticResource BodySecondaryStyle}" />
                            </StackPanel>
                            <Grid x:Name="TerminalStorageMetrics" Grid.Column="1" ColumnSpacing="20" RowSpacing="14">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Storage mapped" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock x:Name="TerminalObserved" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Still unexplained" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock x:Name="TerminalUnobserved" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Spacing="2">
                                    <TextBlock Text="Categorized" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock x:Name="TerminalClassified" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <TextBlock x:Name="TerminalBasisNoteText" Visibility="Collapsed" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                        <Border Style="{StaticResource DividerStyle}" />
                        <Grid x:Name="TerminalDetails" ColumnSpacing="24" RowSpacing="14">
                            <StackPanel x:Name="TerminalDurationMetric" Spacing="2">
                                <TextBlock Text="Time" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="TerminalDuration" Style="{StaticResource StatusTextStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="TerminalFilesMetric" Spacing="2">
                                <TextBlock Text="Files checked" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="TerminalFiles" Style="{StaticResource StatusTextStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="TerminalFoldersMetric" Spacing="2">
                                <TextBlock Text="Folders checked" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="TerminalFolders" Style="{StaticResource StatusTextStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="TerminalCompletedMetric" Spacing="2">
                                <TextBlock Text="Completed" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="TerminalCompleted" Style="{StaticResource StatusTextStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    <Grid x:Name="TerminalWarnings" ColumnSpacing="12" Visibility="Collapsed"
                          AutomationProperties.Name="Analysis warnings" AutomationProperties.LiveSetting="Polite">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE7BA;" FontSize="17" Foreground="{ThemeResource Warning}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="TerminalWarningTitle" Style="{StaticResource StatusTextStyle}" />
                            <TextBlock Text="Some protected or restricted areas could not be fully inspected."
                                       Style="{StaticResource BodyMutedStyle}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="TerminalStaleRetryNoteText" Visibility="Collapsed" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                    <StackPanel x:Name="TerminalActions" Orientation="Horizontal" Spacing="12">
                        <Button x:Name="ResultsButton" Content="View Results" Click="ViewResults"
                                Style="{StaticResource PrimaryActionStyle}" AutomationProperties.Name="View Results" />
                        <Button x:Name="RunAgainButton" Content="Run again" Click="RunAgain"
                                Style="{StaticResource SecondaryActionStyle}" />
                        <Button x:Name="ChangeSetupButton" Content="Change drive" Click="ChangeSetup"
                                Style="{StaticResource QuietButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </controls:ResponsivePageHost.PageContent>
    </controls:ResponsivePageHost>
</Page>
