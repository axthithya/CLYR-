<Page
    x:Class="Clyr.App.Pages.ResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Background="{ThemeResource AppBackground}"
    AutomationProperties.Name="Results page">
    <controls:ResponsivePageHost x:Name="PageHost" Title="Results"
        Subtitle="Understand what is using storage and what is safe to review."
        AutomationProperties.Name="Results responsive page host">
        <controls:ResponsivePageHost.PageContent>
            <StackPanel Spacing="{StaticResource PageSectionSpacing}">

                <!-- Empty state: no analysis has been run yet in this session. -->
                <StackPanel x:Name="EmptyPanel" Spacing="16" AutomationProperties.Name="Results empty state">
                    <controls:EmptyState Title="No analysis results yet"
                        Message="Run a private, read-only analysis to understand what is using storage on your drive."
                        Glyph="&#xE9D2;" />
                    <StackPanel x:Name="EmptyActions" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Content="Analyze drive" Click="AnalyzeDrive" Style="{StaticResource PrimaryActionStyle}" />
                    </StackPanel>
                </StackPanel>

                <!-- Section 3 correction: the normal UI no longer shows a separate "Early Insights" experience —
                     while an analysis is running (or was stopped before completing), Results shows only a brief,
                     honest notice pointing back to the Scan page's own live progress; it never shows provisional
                     contributor/directory/file rankings here. Never shown once a completed result exists
                     (Dashboard, below, is authoritative once available). -->
                <StackPanel x:Name="ProvisionalPanel" Visibility="Collapsed" Spacing="{StaticResource PageSectionSpacing}"
                            AutomationProperties.Name="Analysis in progress">
                    <StackPanel.Transitions>
                        <TransitionCollection><EntranceThemeTransition FromVerticalOffset="8" /></TransitionCollection>
                    </StackPanel.Transitions>
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" MinWidth="0">
                            <TextBlock x:Name="ProvisionalTitleText" Style="{StaticResource CardTitleStyle}"
                                       AutomationProperties.LiveSetting="Polite" />
                            <TextBlock x:Name="ProvisionalSubtitleText" Style="{StaticResource BodySecondaryStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                        <controls:StatusBadge x:Name="ProvisionalBadge" Grid.Column="1" />
                    </Grid>
                    <StackPanel x:Name="ProvisionalActions" Orientation="Horizontal" Spacing="12"
                                AutomationProperties.Name="Analysis in progress actions">
                        <Button Content="View progress" Click="ViewScanProgressFromResults" Style="{StaticResource PrimaryActionStyle}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="Dashboard" Visibility="Collapsed" Spacing="{StaticResource PageSectionSpacing}">
                    <StackPanel.Transitions>
                        <TransitionCollection><EntranceThemeTransition FromVerticalOffset="8" /></TransitionCollection>
                    </StackPanel.Transitions>

                    <!-- 1. Scan identity row -->
                    <Grid ColumnSpacing="12" RowSpacing="8" AutomationProperties.Name="Scan identity">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" MinWidth="0">
                            <TextBlock x:Name="ScanIdentityText" Style="{StaticResource CardTitleStyle}" />
                            <TextBlock x:Name="ScanTimingText" Style="{StaticResource BodySecondaryStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                            <controls:StatusBadge x:Name="StatusBadgeControl" />
                            <controls:StatusBadge x:Name="WarningBadgeControl" Visibility="Collapsed" />
                            <controls:StatusBadge x:Name="ScanLimitBadgeControl" Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>

                    <!-- 2. Main summary hero -->
                    <Border Style="{StaticResource StandardCardStyle}" AutomationProperties.Name="What CLYR found">
                        <StackPanel Spacing="18">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="What CLYR found" Style="{StaticResource SectionTitleStyle}"
                                               AutomationProperties.HeadingLevel="Level2" />
                                    <TextBlock x:Name="AccountedDescriptionText" Style="{StaticResource BodySecondaryStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock x:Name="AccountedPercentValue" Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Right" />
                                    <TextBlock x:Name="AccountedPercentCaptionText" Text="Coverage" Style="{StaticResource MetricLabelStyle}" HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                            <Grid x:Name="StorageVisualization" Height="16" Background="{ThemeResource SurfaceSecondary}"
                                  CornerRadius="8" AutomationProperties.Name="Drive storage breakdown">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="AccountedColumn" Width="0*" />
                                    <ColumnDefinition x:Name="NotObservedColumn" Width="0*" />
                                    <ColumnDefinition x:Name="FreeColumn" Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AccountedSegment" Background="{ThemeResource AccentPrimary}" CornerRadius="8,0,0,8" />
                                <Border x:Name="NotObservedSegment" Grid.Column="1" Background="{ThemeResource BorderStrong}" />
                            </Grid>
                            <Border x:Name="AccountingBasisDiffersPanel" Visibility="Collapsed" Padding="14,10"
                                    Background="{ThemeResource SurfaceSecondary}" CornerRadius="{StaticResource CornerRadiusControl}"
                                    AutomationProperties.Name="Accounting basis differs explanation">
                                <TextBlock x:Name="AccountingBasisDiffersText" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                            </Border>
                            <Grid x:Name="StorageMetrics" ColumnSpacing="24" RowSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="DriveUsedMetricPanel" Spacing="3">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Width="8" Height="8" CornerRadius="2" Background="{ThemeResource AccentPrimary}" />
                                        <TextBlock x:Name="AccountedMetricLabel" Text="Storage mapped" Style="{StaticResource MetricLabelStyle}" />
                                    </StackPanel>
                                    <TextBlock x:Name="AccountedMetric" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="NotObservedMetricPanel" Grid.Column="1" Spacing="3">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Width="8" Height="8" CornerRadius="2" Background="{ThemeResource BorderStrong}" />
                                        <TextBlock Text="Still unexplained" Style="{StaticResource MetricLabelStyle}" />
                                    </StackPanel>
                                    <TextBlock x:Name="NotObservedMetric" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="FreeMetricPanel" Grid.Column="2" Spacing="3">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Width="8" Height="8" CornerRadius="2" Background="{ThemeResource SurfaceSecondary}" BorderBrush="{ThemeResource BorderSubtle}" BorderThickness="1" />
                                        <TextBlock Text="Free space" Style="{StaticResource MetricLabelStyle}" />
                                    </StackPanel>
                                    <TextBlock x:Name="FreeMetric" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="DriveUsedTotalPanel" Grid.Column="3" Spacing="3">
                                    <TextBlock Text="Windows reports used" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock x:Name="DriveUsedMetric" Style="{StaticResource CardTitleStyle}" />
                                </StackPanel>
                            </Grid>
                            <Border Style="{StaticResource DividerStyle}" />
                            <!-- Section 4 correction: Coverage is already the large top-right value — repeating it
                                 here as well read as duplicated information. Only Categorized (a distinct concept)
                                 remains in this row. -->
                            <StackPanel Spacing="2">
                                <TextBlock Text="Categorized" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ClassificationHeadlineText" Style="{StaticResource StatusTextStyle}" />
                            </StackPanel>
                            <TextBlock x:Name="ClassificationRetryNoteText" Visibility="Collapsed" Style="{StaticResource CaptionStyle}"
                                       TextWrapping="Wrap" AutomationProperties.Name="Why the categorized percentage changed" />
                        </StackPanel>
                    </Border>

                    <!-- 3. Administrator retry — kept directly below the main summary so a successful retry is
                         never buried at the bottom of a long page (see section 9). -->
                    <Border x:Name="AdministratorRetryCard" Style="{StaticResource CompactCardStyle}" Visibility="Collapsed"
                            AutomationProperties.Name="Administrator retry for restricted scan areas">
                        <StackPanel Spacing="10">
                            <controls:SectionHeader x:Name="AdministratorRetryHeader" Title="Administrator retry"
                                Description="Some folders could not be fully inspected. CLYR can retry only those scan areas with administrator access." />
                            <!-- Section 3 correction: the terminal summary must appear above the retry button, never
                                 be replaced by it — a successful (or otherwise concluded) retry keeps its summary
                                 visible even when further restricted roots still make another retry available. -->
                            <InfoBar x:Name="AdministratorRetryInfoBar" IsOpen="False" IsClosable="False" CornerRadius="{StaticResource CornerRadiusControl}" />
                            <TextBlock x:Name="AdministratorRetrySummary" Style="{StaticResource BodySecondaryStyle}" TextWrapping="Wrap" Visibility="Collapsed" />
                            <Grid x:Name="AdministratorRetryComparison" Visibility="Collapsed" ColumnSpacing="16" RowSpacing="4"
                                  AutomationProperties.Name="Administrator retry coverage comparison">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Coverage" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock x:Name="AdministratorRetryCoverageText" Style="{StaticResource BodyStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Newly found storage" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock x:Name="AdministratorRetryNewlyAccountedText" Style="{StaticResource BodyStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="Restricted areas" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock x:Name="AdministratorRetryAreasText" Style="{StaticResource BodyStyle}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock x:Name="AdministratorRetryBasisNoteText" Visibility="Collapsed" Style="{StaticResource CaptionStyle}"
                                       TextWrapping="Wrap" AutomationProperties.Name="Administrator retry accounting basis note" />
                            <Button x:Name="AdministratorRetryButton" Click="RequestAdministratorRetry" Style="{StaticResource SecondaryActionStyle}"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.HelpText="Optional, read-only. Retries only the restricted scan areas with administrator permission. Does not delete, move, rename, or modify files." />
                            <StackPanel x:Name="AdministratorRetryRunningPanel" Spacing="6" Visibility="Collapsed">
                                <ProgressBar x:Name="AdministratorRetryProgress" IsIndeterminate="True" Height="4" />
                                <TextBlock x:Name="AdministratorRetryElapsedText" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap"
                                           AutomationProperties.LiveSetting="Polite" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 4. Analysis quality, with technical detail consolidated into one expander -->
                    <Border Style="{StaticResource CompactCardStyle}" AutomationProperties.Name="Analysis quality">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Analysis quality" Style="{StaticResource CardTitleStyle}" />
                                    <TextBlock x:Name="QualityDescriptionText" Style="{StaticResource BodySecondaryStyle}" />
                                </StackPanel>
                                <controls:StatusBadge x:Name="QualityBadgeControl" Grid.Column="1" VerticalAlignment="Top" />
                            </Grid>
                            <Expander x:Name="LimitationsExpander" Header="How these numbers are calculated"
                                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                      AutomationProperties.Name="How these numbers are calculated">
                                <ItemsControl x:Name="LimitationRows" AutomationProperties.Name="Limitation details">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:KeyValueRow Label="{Binding Label}" Value="{Binding Value}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <!-- 5. Why is this drive full -->
                    <StackPanel x:Name="ContributorsSection" Spacing="14" AutomationProperties.Name="Why is this drive full">
                        <controls:SectionHeader x:Name="ContributorsHeader" Title="Why is this drive full?"
                            Description="Ranked contributors include exact sizes so the ranking never relies on color alone." />
                        <ItemsControl x:Name="ContributorList" AutomationProperties.Name="Ranked storage contributors">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12" ColumnSpacing="12" AutomationProperties.Name="{Binding AccessibleText}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" /><ColumnDefinition Width="26" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Rank}" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center" />
                                        <FontIcon Grid.Column="1" Glyph="{Binding Glyph}" FontSize="15" Foreground="{ThemeResource TextSecondary}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="2" MinWidth="0" Spacing="5" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStyle}" TextTrimming="CharacterEllipsis" />
                                            <ProgressBar Value="{Binding PercentageValue}" Minimum="0" Maximum="100" Height="4"
                                                         Foreground="{ThemeResource AccentPrimary}" Background="{ThemeResource SurfaceSecondary}"
                                                         IsHitTestVisible="False" AutomationProperties.Name="{Binding AccessibleText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Size}" Style="{StaticResource StatusTextStyle}" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding Percentage}" Style="{StaticResource CaptionStyle}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button x:Name="ContributorsExpandButton" Click="ToggleContributors" Style="{StaticResource QuietButtonStyle}"
                                HorizontalAlignment="Left" Visibility="Collapsed" />
                    </StackPanel>

                    <!-- 6. Findings -->
                    <StackPanel x:Name="FindingsSection" Spacing="14" AutomationProperties.Name="Findings">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <controls:SectionHeader Title="Findings" Description="Specific storage patterns CLYR recognized, with explanations and safety guidance." />
                            <ComboBox x:Name="FindingFilter" Grid.Column="1" VerticalAlignment="Top" MinWidth="90"
                                      SelectionChanged="FindingFilterChanged" AutomationProperties.Name="Filter findings by confidence" />
                        </Grid>
                        <ItemsControl x:Name="FindingList" AutomationProperties.Name="Storage findings">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,10" AutomationProperties.Name="{Binding AccessibleText}"
                                            ToolTipService.ToolTip="{Binding TechnicalDetail}">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource BodyStyle}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="1" Text="{Binding Size}" Style="{StaticResource StatusTextStyle}" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="{Binding NaturalStatus}" Style="{StaticResource CaptionStyle}" />
                                            <TextBlock Text="{Binding Explanation}" Style="{StaticResource BodySecondaryStyle}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoFindingsText" Style="{StaticResource BodySecondaryStyle}" Visibility="Collapsed"
                                   Text="No findings match the selected filter." />
                        <TextBlock x:Name="FindingsProvenanceText" Visibility="Collapsed" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- 7. Largest directories and files -->
                    <StackPanel x:Name="DirectoriesSection" Spacing="14" Visibility="Collapsed" AutomationProperties.Name="Largest directories">
                        <controls:SectionHeader Title="Largest top-level folders"
                            Description="Main folders directly inside this drive. These values do not overlap." />
                        <ItemsControl x:Name="DirectoryList" AutomationProperties.Name="Largest top-level folders list">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="44" ColumnSpacing="12" AutomationProperties.Name="{Binding AccessibleText}"
                                          ToolTipService.ToolTip="{Binding FullPath}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE8B7;" FontSize="15" Foreground="{ThemeResource TextSecondary}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStyle}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ShortPath}" Style="{StaticResource CaptionStyle}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Size}" Style="{StaticResource StatusTextStyle}" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding Percentage}" Style="{StaticResource CaptionStyle}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button x:Name="ShowAllFoldersButton" Click="ToggleTopLevelDirectories" Style="{StaticResource QuietButtonStyle}"
                                HorizontalAlignment="Left" Visibility="Collapsed" />
                        <Expander x:Name="NestedDirectoriesExpander" Header="Largest nested folders" Visibility="Collapsed"
                                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                  AutomationProperties.Name="Largest nested folders, deeper than the drive root">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Nested folders can overlap with parent folders shown above and should not be added together."
                                           Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                                <ItemsControl x:Name="NestedDirectoryList" AutomationProperties.Name="Largest nested folders list">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid MinHeight="44" ColumnSpacing="12" AutomationProperties.Name="{Binding AccessibleText}"
                                                  ToolTipService.ToolTip="{Binding FullPath}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xE8B7;" FontSize="15" Foreground="{ThemeResource TextSecondary}" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStyle}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding ShortPath}" Style="{StaticResource CaptionStyle}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Size}" Style="{StaticResource StatusTextStyle}" HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding Percentage}" Style="{StaticResource CaptionStyle}" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander>
                        <TextBlock x:Name="DirectoriesProvenanceText" Visibility="Collapsed" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel x:Name="FilesSection" Spacing="14" Visibility="Collapsed" AutomationProperties.Name="Largest files">
                        <controls:SectionHeader Title="Largest files" Description="Individual files observed with the largest logical size. Percentages show share of observed logical storage." />
                        <ItemsControl x:Name="FileList" AutomationProperties.Name="Largest files list">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="44" ColumnSpacing="12" AutomationProperties.Name="{Binding AccessibleText}"
                                          ToolTipService.ToolTip="{Binding FullPath}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE7C3;" FontSize="15" Foreground="{ThemeResource TextSecondary}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStyle}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ShortPath}" Style="{StaticResource CaptionStyle}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Size}" Style="{StaticResource StatusTextStyle}" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding Percentage}" Style="{StaticResource CaptionStyle}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="FilesProvenanceText" Visibility="Collapsed" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- 9. Final action area -->
                    <Border Style="{StaticResource DividerStyle}" Margin="0,4" />
                    <StackPanel x:Name="FinalActionArea" Orientation="Horizontal" Spacing="12" AutomationProperties.Name="Results actions">
                        <Button Content="Review potential actions" Click="ReviewActions" Style="{StaticResource PrimaryActionStyle}" />
                        <Button Content="Export privacy-safe report" IsEnabled="False" Style="{StaticResource SecondaryActionStyle}"
                                ToolTipService.ToolTip="Use the CLI export option in this preview build." />
                        <Button Content="Run another analysis" Click="RunAgain" Style="{StaticResource QuietButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </controls:ResponsivePageHost.PageContent>
    </controls:ResponsivePageHost>
</Page>
