<Page
    x:Class="Clyr.App.Pages.ResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Background="{ThemeResource AppBackgroundBrush}"
    AutomationProperties.Name="Results page">
    <controls:ResponsivePageHost x:Name="PageHost" Title="Results"
        Subtitle="Understand the latest analysis through clear aggregates, evidence, and limitations."
        AutomationProperties.Name="Results responsive page host">
        <controls:ResponsivePageHost.PageContent>
            <StackPanel Spacing="24">
                <StackPanel x:Name="EmptyPanel" Spacing="16" AutomationProperties.Name="Results empty state">
                    <controls:EmptyState Title="No analysis results yet" Message="Run a private, read-only analysis to understand what is using space on your drive." Glyph="&#xE9D2;"/>
                    <StackPanel x:Name="EmptyActions" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center"><Button Content="Run Quick Analysis" Click="RunQuick" Style="{StaticResource PrimaryActionStyle}"/><Button Content="Run Deep Analysis" Click="RunDeep"/></StackPanel>
                </StackPanel>
                <StackPanel x:Name="Dashboard" Visibility="Collapsed" Spacing="24">
                    <Grid x:Name="MetricGrid" ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border x:Name="DriveUsedCard" Style="{StaticResource CardStyle}" AutomationProperties.Name="Drive used metric card"><StackPanel><TextBlock Text="Drive used" Style="{StaticResource BodyMutedStyle}"/><TextBlock x:Name="DriveUsedMetric" FontSize="22" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border x:Name="ObservedCard" Grid.Column="1" Style="{StaticResource CardStyle}" AutomationProperties.Name="Observed logical size metric card"><StackPanel><TextBlock Text="Observed logical size" Style="{StaticResource BodyMutedStyle}"/><TextBlock x:Name="ObservedMetric" FontSize="22" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border x:Name="CoverageCard" Grid.Column="2" Style="{StaticResource CardStyle}" AutomationProperties.Name="Classification coverage metric card"><StackPanel><TextBlock Text="Classification coverage" Style="{StaticResource BodyMutedStyle}"/><TextBlock x:Name="CoverageMetric" FontSize="22" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border x:Name="UnknownCard" Grid.Column="3" Style="{StaticResource CardStyle}" AutomationProperties.Name="Unknown storage metric card"><StackPanel><TextBlock Text="Unknown storage" Style="{StaticResource BodyMutedStyle}"/><TextBlock x:Name="UnknownMetric" FontSize="22" FontWeight="SemiBold"/></StackPanel></Border>
                    </Grid>
                    <Grid x:Name="ContentGrid" ColumnSpacing="20" RowSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border x:Name="ContributorPanel" Style="{StaticResource CardStyle}" AutomationProperties.Name="Contributor visualization"><StackPanel Spacing="14"><TextBlock Text="Why is this drive full?" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="Ranked contributors include exact textual sizes so the visualization never relies on color alone." Style="{StaticResource BodyMutedStyle}"/><ListView x:Name="ContributorList" MaxHeight="420" AutomationProperties.Name="Contributor text alternatives"/></StackPanel></Border>
                        <StackPanel x:Name="ResultSidebar" Grid.Column="1" Spacing="16"><Border Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="Scan status" Style="{StaticResource CardTitleStyle}"/><TextBlock x:Name="ScanSummary" Style="{StaticResource BodyMutedStyle}"/></StackPanel></Border><Border Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="Limitations" Style="{StaticResource CardTitleStyle}"/><TextBlock x:Name="Limitations" Style="{StaticResource BodyMutedStyle}"/></StackPanel></Border><Button Content="Review potential actions" Click="ReviewActions" Style="{StaticResource PrimaryActionStyle}"/><Button Content="Export privacy-safe report" IsEnabled="False" ToolTipService.ToolTip="Use the CLI export option in this preview build."/><Button Content="Run another analysis" Click="RunAgain"/></StackPanel>
                    </Grid>
                    <TextBlock Text="Findings" Style="{StaticResource SectionTitleStyle}"/><ListView x:Name="FindingList" MaxHeight="420" AutomationProperties.Name="Storage findings"/>
                    <TextBlock x:Name="DirectoryHeading" Text="Largest directories" Style="{StaticResource SectionTitleStyle}"/><ListView x:Name="DirectoryList" MaxHeight="320"/>
                </StackPanel>
            </StackPanel>
        </controls:ResponsivePageHost.PageContent>
    </controls:ResponsivePageHost>
</Page>
