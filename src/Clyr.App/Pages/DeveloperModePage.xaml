<Page
    x:Class="Clyr.App.Pages.DeveloperModePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Background="{ThemeResource AppBackgroundBrush}"
    AutomationProperties.Name="Developer Mode page">
    <controls:ResponsivePageHost x:Name="PageHost" Title="Developer Mode"
        Subtitle="Understand storage used by development tools and local environments. Nothing is changed automatically."
        AutomationProperties.Name="Developer Mode responsive page host">
        <controls:ResponsivePageHost.PageContent>
            <StackPanel Spacing="24">
                <Border Style="{StaticResource CardStyle}" Background="{ThemeResource PrivacyBannerBrush}" AutomationProperties.Name="Developer Mode boundary notice">
                    <TextBlock TextWrapping="Wrap" Text="Developer Mode reports storage for a narrow set of developer tools using read-only detection only. It never adds, updates, or removes tool data on its own. Any eligible finding routes through the same plan review used everywhere else in CLYR."/>
                </Border>

                <Grid x:Name="SnapshotGrid" ColumnSpacing="12" RowSpacing="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <ComboBox x:Name="SnapshotPicker" Header="Local analysis to inspect" HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Local analysis to inspect" SelectionChanged="SnapshotSelectionChanged"/>
                    <Button x:Name="DetectButton" Grid.Column="1" VerticalAlignment="Bottom" Content="Detect developer tools"
                        Click="DetectClick" Style="{StaticResource PrimaryActionStyle}" AutomationProperties.Name="Detect developer tools"/>
                </Grid>
                <TextBlock x:Name="DeveloperStatus" Style="{StaticResource BodyMutedStyle}" AutomationProperties.LiveSetting="Polite"/>

                <StackPanel x:Name="DeveloperEmpty" Spacing="16" AutomationProperties.Name="Developer Mode empty state">
                    <controls:EmptyState Title="No developer tool detection yet" Message="Run or select a local analysis, then choose Detect developer tools."
                        Glyph="&#xE943;"/>
                </StackPanel>

                <StackPanel x:Name="DeveloperContent" Visibility="Collapsed" Spacing="18">
                    <TextBlock Text="Detected developer tools" Style="{StaticResource SectionTitleStyle}"/>
                    <Grid x:Name="ToolGrid" ColumnSpacing="14" RowSpacing="14" AutomationProperties.Name="Developer tool cards">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    </Grid>
                </StackPanel>

                <Border x:Name="DetailPanel" Style="{StaticResource CardStyle}" Visibility="Collapsed" AutomationProperties.Name="Developer tool detail">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="DetailTitle" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock x:Name="DetailExplanation" Style="{StaticResource BodyMutedStyle}" TextWrapping="Wrap"/>
                        <StackPanel x:Name="DetailDiagnosticsStack" Spacing="6"/>
                        <StackPanel x:Name="DetailStack" Spacing="10"/>
                        <Button Content="Close details" Click="CloseDetails" AutomationProperties.Name="Close developer tool details"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </controls:ResponsivePageHost.PageContent>
    </controls:ResponsivePageHost>
</Page>
