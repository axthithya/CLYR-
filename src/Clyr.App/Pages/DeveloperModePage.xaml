<Page
    x:Class="Clyr.App.Pages.DeveloperModePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Background="{ThemeResource AppBackgroundBrush}"
    AutomationProperties.Name="Developer Mode page">
    <controls:ResponsivePageHost x:Name="PageHost" Title="Developer Mode"
        Subtitle="Understand storage used by development tools and local environments."
        AutomationProperties.Name="Developer Mode responsive page host">
        <controls:ResponsivePageHost.PageContent>
            <StackPanel Spacing="24">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="10"><TextBlock Text="A focused developer view is coming later" Style="{StaticResource SectionTitleStyle}"/><TextBlock Text="Current analyses may classify some developer storage, but tool-aware analysis and cleanup are not available. These preview tiles are informational only." Style="{StaticResource BodyMutedStyle}"/></StackPanel>
                </Border>
                <TextBlock Text="Planned tool-aware views" Style="{StaticResource SectionTitleStyle}"/>
                <Grid x:Name="ToolGrid" ColumnSpacing="14" RowSpacing="14" AutomationProperties.Name="Developer tool preview tiles">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                </Grid>
                <TextBlock Text="Tool detection and tool-aware cleanup remain unavailable until a separately approved future phase." Style="{StaticResource BodyMutedStyle}"/>
            </StackPanel>
        </controls:ResponsivePageHost.PageContent>
    </controls:ResponsivePageHost>
</Page>
