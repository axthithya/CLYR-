<Page
    x:Class="Clyr.App.Pages.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Background="{ThemeResource AppBackground}"
    AutomationProperties.Name="Overview page">
    <controls:ResponsivePageHost
        x:Name="PageHost"
        Title="Overview"
        Subtitle="Understand your drive and decide what to do next."
        AutomationProperties.Name="Overview responsive page host">
        <controls:ResponsivePageHost.PageContent>
            <StackPanel x:Name="OverviewContent" Spacing="28">
                <Border
                    x:Name="DriveHero"
                    Padding="24"
                    Background="{ThemeResource SurfacePrimary}"
                    BorderBrush="{ThemeResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusLargeSurface}"
                    AutomationProperties.Name="System drive health">
                    <StackPanel Spacing="20">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel MinWidth="0" Spacing="4">
                                <TextBlock x:Name="DriveIdentity" Style="{StaticResource SectionTitleStyle}"
                                           AutomationProperties.HeadingLevel="Level2" />
                                <TextBlock x:Name="DriveLatestState" Style="{StaticResource BodyMutedStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock x:Name="DriveUsedPercentage" Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Right" />
                                <TextBlock Text="used" Style="{StaticResource MetricLabelStyle}" HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="StorageVisualization" Height="16" Background="{ThemeResource SurfaceSecondary}"
                              CornerRadius="8" AutomationProperties.Name="Drive storage usage">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="DriveUsedColumn" Width="0*" />
                                <ColumnDefinition x:Name="DriveFreeColumn" Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="UsedStorageSegment" Background="{ThemeResource AccentPrimary}" CornerRadius="8,0,0,8" />
                        </Grid>
                        <Grid x:Name="DriveMetrics" ColumnSpacing="24" RowSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <StackPanel x:Name="DriveUsedMetric" Spacing="3">
                                <TextBlock Text="Used storage" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="DriveUsedValue" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="DriveFreeMetric" Grid.Column="1" Spacing="3">
                                <TextBlock Text="Free storage" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="DriveFreeValue" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="DriveTotalMetric" Grid.Column="2" Spacing="3">
                                <TextBlock Text="Total capacity" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="DriveTotalValue" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel x:Name="DriveReadyMetric" Grid.Column="3" Spacing="3">
                                <TextBlock Text="Scan readiness" Style="{StaticResource MetricLabelStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <FontIcon x:Name="DriveReadinessIcon" Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource Success}" />
                                    <TextBlock x:Name="DriveReadiness" Style="{StaticResource StatusTextStyle}" />
                                </StackPanel>
                                <TextBlock x:Name="DriveFileSystem" Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <Grid x:Name="PrimaryActionArea" AutomationProperties.LiveSetting="Polite">
                    <StackPanel x:Name="FirstRunPanel" Spacing="16" AutomationProperties.Name="No analysis yet">
                        <StackPanel.Transitions>
                            <TransitionCollection><EntranceThemeTransition FromVerticalOffset="8" /></TransitionCollection>
                        </StackPanel.Transitions>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" Background="{ThemeResource SurfaceSelected}" CornerRadius="22">
                                <FontIcon Glyph="&#xE721;" FontSize="20" Foreground="{ThemeResource AccentPrimary}" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="No analysis yet" Style="{StaticResource SectionTitleStyle}"
                                           AutomationProperties.HeadingLevel="Level2" />
                                <TextBlock Text="Run a private, read-only analysis to understand what is using storage."
                                           Style="{StaticResource BodySecondaryStyle}" />
                            </StackPanel>
                        </Grid>
                        <StackPanel x:Name="FirstRunActions" Orientation="Horizontal" Spacing="12">
                            <Button Content="Analyze drive" Click="AnalyzeDrive" Style="{StaticResource PrimaryActionStyle}"
                                    AutomationProperties.Name="Analyze drive" />
                        </StackPanel>
                    </StackPanel>
                    <!-- Section 16 correction: a saved analysis from a previous session must never be hidden
                         behind the generic "No analysis yet" first-run state — this card truthfully surfaces it,
                         sourced directly from local History, and is only ever shown when no result exists yet in
                         this running session. -->
                    <StackPanel x:Name="SavedOnlyPanel" Spacing="16" Visibility="Collapsed"
                                AutomationProperties.Name="Latest saved analysis">
                        <StackPanel.Transitions>
                            <TransitionCollection><EntranceThemeTransition FromVerticalOffset="8" /></TransitionCollection>
                        </StackPanel.Transitions>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" Background="{ThemeResource SurfaceSelected}" CornerRadius="22">
                                <FontIcon Glyph="&#xE81C;" FontSize="20" Foreground="{ThemeResource AccentPrimary}" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Latest saved analysis" Style="{StaticResource SectionTitleStyle}"
                                           AutomationProperties.HeadingLevel="Level2" />
                                <TextBlock x:Name="SavedOnlyCompletedText" Style="{StaticResource BodySecondaryStyle}" />
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Storage mapped" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="SavedOnlyMappedText" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="Coverage" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="SavedOnlyCoverageText" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="This is from a previous session, saved in your local history."
                                   Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="View in History" Click="ViewHistory" Style="{StaticResource PrimaryActionStyle}" />
                            <Button Content="Analyze again" Click="AnalyzeDrive" Style="{StaticResource SecondaryActionStyle}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel x:Name="RunningPanel" Spacing="12" Visibility="Collapsed"
                                AutomationProperties.Name="Analysis in progress" AutomationProperties.LiveSetting="Polite">
                        <StackPanel.Transitions>
                            <TransitionCollection><EntranceThemeTransition FromVerticalOffset="8" /></TransitionCollection>
                        </StackPanel.Transitions>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" Background="{ThemeResource SurfaceSelected}" CornerRadius="22">
                                <FontIcon Glyph="&#xE895;" FontSize="20" Foreground="{ThemeResource AccentPrimary}" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Analysis in progress" Style="{StaticResource SectionTitleStyle}"
                                           AutomationProperties.HeadingLevel="Level2" />
                                <TextBlock x:Name="RunningSummaryText" Style="{StaticResource BodySecondaryStyle}" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="View progress" Click="ViewScanProgress" Style="{StaticResource SecondaryActionStyle}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel x:Name="ResultActionPanel" Spacing="12" Visibility="Collapsed"
                                AutomationProperties.Name="Recommended next action">
                        <TextBlock Text="Your latest analysis is ready" Style="{StaticResource CardTitleStyle}" />
                        <StackPanel x:Name="ResultActions" Orientation="Horizontal" Spacing="12">
                            <Button Content="View latest results" Click="ViewResults" Style="{StaticResource PrimaryActionStyle}" />
                            <Button Content="Run another analysis" Click="RunAgain" Style="{StaticResource SecondaryActionStyle}" />
                            <Button x:Name="ResultReviewAction" Content="Review potential actions" Click="ReviewActions"
                                    Style="{StaticResource QuietButtonStyle}" Visibility="Collapsed" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <StackPanel x:Name="LatestAnalysisSection" Spacing="16" Visibility="Collapsed"
                            AutomationProperties.Name="Latest analysis summary">
                    <StackPanel.Transitions>
                        <TransitionCollection><EntranceThemeTransition FromVerticalOffset="8" /></TransitionCollection>
                    </StackPanel.Transitions>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Latest analysis" Style="{StaticResource SectionTitleStyle}"
                                       AutomationProperties.HeadingLevel="Level2" />
                            <TextBlock x:Name="LatestIdentity" Style="{StaticResource BodyMutedStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" VerticalAlignment="Top">
                            <TextBlock x:Name="LatestQuality" Style="{StaticResource StatusTextStyle}"
                                       AutomationProperties.LiveSetting="Polite" />
                        </Border>
                    </Grid>
                    <Grid x:Name="CoverageSummary" ColumnSpacing="28" RowSpacing="18">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4*" /><ColumnDefinition Width="3*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="LatestCoverageValue" FontSize="36" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimary}" />
                            <TextBlock x:Name="LatestCoverageDescription" Style="{StaticResource BodySecondaryStyle}" />
                        </StackPanel>
                        <Grid x:Name="LatestMetrics" Grid.Column="1" ColumnSpacing="20" RowSpacing="14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Observed" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ObservedValue" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="Not observed" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="UnobservedValue" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Spacing="2">
                                <TextBlock Text="Classified of observed" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ClassifiedValue" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                <TextBlock Text="Examined" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ExaminedValue" Style="{StaticResource CardTitleStyle}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <Border Style="{StaticResource DividerStyle}" />
                    <Grid x:Name="WarningSummary" ColumnSpacing="12" Visibility="Collapsed"
                          AutomationProperties.Name="Analysis warnings" AutomationProperties.LiveSetting="Polite">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE7BA;" FontSize="17" Foreground="{ThemeResource Warning}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="WarningTitle" Style="{StaticResource StatusTextStyle}" />
                            <TextBlock Text="Some Windows-managed areas could not be fully inspected. The usable results remain available."
                                       Style="{StaticResource BodyMutedStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
                    <Grid x:Name="PreviewGrid" ColumnSpacing="32" RowSpacing="28">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="4*" /><ColumnDefinition Width="3*" /></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel x:Name="ContributorsSection" Spacing="14" Visibility="Collapsed"
                                AutomationProperties.Name="Top storage contributors">
                        <TextBlock Text="Top storage contributors" Style="{StaticResource SectionTitleStyle}"
                                   AutomationProperties.HeadingLevel="Level2" />
                        <ItemsControl x:Name="TopContributors" AutomationProperties.Name="Ranked storage contributors">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,13" ColumnSpacing="12" AutomationProperties.Name="{Binding AccessibleText}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Rank}" Style="{StaticResource CaptionStyle}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" MinWidth="0" Spacing="5">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStyle}" TextTrimming="CharacterEllipsis"
                                                       ToolTipService.ToolTip="{Binding Name}" />
                                            <ProgressBar Value="{Binding PercentageValue}" Minimum="0" Maximum="100" Height="4"
                                                         Foreground="{ThemeResource AccentPrimary}" Background="{ThemeResource SurfaceSecondary}"
                                                         IsHitTestVisible="False" AutomationProperties.Name="{Binding AccessibleText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Size}" Style="{StaticResource StatusTextStyle}" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding Percentage}" Style="{StaticResource CaptionStyle}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="View all results" Click="ViewResults" Style="{StaticResource QuietButtonStyle}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel x:Name="ActivitySection" Grid.Column="1" Spacing="14" Visibility="Collapsed"
                                AutomationProperties.Name="Recent analysis activity">
                        <TextBlock Text="Recent activity" Style="{StaticResource SectionTitleStyle}"
                                   AutomationProperties.HeadingLevel="Level2" />
                        <ItemsControl x:Name="RecentActivity" AutomationProperties.Name="Recent analyses">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,14" ColumnSpacing="10" AutomationProperties.Name="{Binding AccessibleText}">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE823;" FontSize="15" Foreground="{ThemeResource TextMuted}" Margin="0,2,0,0" />
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource BodyStyle}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Status}" Style="{StaticResource CaptionStyle}" />
                                            </Grid>
                                            <TextBlock Text="{Binding Detail}" Style="{StaticResource CaptionStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="View history" Click="ViewHistory" Style="{StaticResource QuietButtonStyle}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                    <Border x:Name="ReviewPlanPreview" Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource InfoBannerStyle}"
                            Visibility="Collapsed" AutomationProperties.Name="Potential actions ready for review">
                        <Grid x:Name="ReviewPlanLayout" ColumnSpacing="20" RowSpacing="14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <FontIcon Glyph="&#xE9D5;" FontSize="22" Foreground="{ThemeResource Information}" VerticalAlignment="Top" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Potential actions ready for review" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock x:Name="ReviewPlanSummary" Style="{StaticResource BodySecondaryStyle}" />
                                <TextBlock Text="Nothing will be changed without your confirmation. Potential storage is observed evidence, not guaranteed reclaimable space."
                                           Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                            <Button x:Name="ReviewPlanButton" Grid.Column="2" Content="Review potential actions" Click="ReviewActions"
                                    Style="{StaticResource SecondaryActionStyle}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </controls:ResponsivePageHost.PageContent>
    </controls:ResponsivePageHost>
</Page>
