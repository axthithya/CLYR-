<Page
    x:Class="Clyr.App.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Background="{ThemeResource AppBackgroundBrush}"
    AutomationProperties.Name="About page">
    <controls:ResponsivePageHost x:Name="PageHost" Title="About CLYR"
        Subtitle="See what filled your C: drive. Understand it. Clear it safely."
        AutomationProperties.Name="About responsive page host">
        <controls:ResponsivePageHost.PageContent>
            <StackPanel Spacing="22">
                <Border Style="{StaticResource CardStyle}" Padding="28">
                    <Grid x:Name="IdentityGrid" ColumnSpacing="24" RowSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border x:Name="ProductMark" Width="72" Height="72" CornerRadius="18" Background="{ThemeResource WarmAccentBrush}"><TextBlock Text="C:" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <StackPanel x:Name="ProductCopy" Grid.Column="1" Spacing="7" MinWidth="0"><TextBlock Text="CLYR" FontSize="30" FontWeight="SemiBold"/><TextBlock x:Name="VersionText" AutomationProperties.Name="About version text"/><TextBlock Text="A private Windows utility that explains storage pressure before any future action." Style="{StaticResource BodyMutedStyle}"/></StackPanel>
                    </Grid>
                </Border>
                <Grid x:Name="CapabilityGrid" ColumnSpacing="20" RowSpacing="20">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="Current capabilities" Style="{StaticResource CardTitleStyle}"/><TextBlock Text="Private read-only analysis · storage classification · local aggregate history · privacy-safe reports" Style="{StaticResource BodyMutedStyle}"/></StackPanel></Border>
                    <Border x:Name="UnavailableCard" Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="Not available yet" Style="{StaticResource CardTitleStyle}"/><TextBlock Text="Cleanup · file movement · tool-aware developer analysis · elevated operations" Style="{StaticResource BodyMutedStyle}"/></StackPanel></Border>
                </Grid>
                <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="Privacy promise" Style="{StaticResource CardTitleStyle}"/><TextBlock Text="Analysis stays on this device. CLYR does not upload your scan, read file contents, or change your files." Style="{StaticResource BodyMutedStyle}"/></StackPanel></Border>
                <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="Technical details" Style="{StaticResource CardTitleStyle}"/><TextBlock x:Name="TechnicalText" Style="{StaticResource BodyMutedStyle}"/><TextBlock Text="Open-source · Windows 10 and Windows 11 developer preview · repository link is not configured in this build." Style="{StaticResource BodyMutedStyle}"/></StackPanel></Border>
            </StackPanel>
        </controls:ResponsivePageHost.PageContent>
    </controls:ResponsivePageHost>
</Page>
