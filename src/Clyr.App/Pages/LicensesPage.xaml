<Page
    x:Class="Clyr.App.Pages.LicensesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Background="{ThemeResource AppBackgroundBrush}"
    AutomationProperties.Name="Licenses page">
    <Page.Resources>
        <DataTemplate x:Key="WideLicenseTemplate">
            <Grid ColumnSpacing="18" Padding="4,10" ToolTipService.ToolTip="{Binding Summary}">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Package}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding Version}" Style="{StaticResource BodyMutedStyle}" VerticalAlignment="Center"/>
                <Border Grid.Column="2" Background="{ThemeResource TrustBadgeBackgroundBrush}" BorderBrush="{ThemeResource TrustBadgeBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="9,4"><TextBlock Text="{Binding License}" FontSize="12"/></Border>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NarrowLicenseTemplate">
            <StackPanel Spacing="5" Padding="4,10" ToolTipService.ToolTip="{Binding Summary}">
                <TextBlock Text="{Binding Package}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Metadata}" Style="{StaticResource BodyMutedStyle}"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>
    <controls:ResponsivePageHost x:Name="PageHost" Title="Licenses"
        Subtitle="Open-source licenses and third-party software included with CLYR."
        AutomationProperties.Name="Licenses responsive page host">
        <controls:ResponsivePageHost.PageContent>
            <StackPanel Spacing="20">
                <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="CLYR" Style="{StaticResource CardTitleStyle}"/><TextBlock Text="Open-source project · license details are provided in the repository." Style="{StaticResource BodyMutedStyle}"/></StackPanel></Border>
                <TextBox x:Name="LicenseSearch" Header="Search dependencies" PlaceholderText="Name, version, or license" HorizontalAlignment="Stretch" TextChanged="SearchChanged" AutomationProperties.Name="Search third-party licenses"/>
                <ListView x:Name="LicenseList" MaxHeight="500" HorizontalContentAlignment="Stretch" AutomationProperties.Name="Third-party license inventory"/>
                <TextBlock Text="Dependency versions are pinned and reviewed through the repository verification process." Style="{StaticResource BodyMutedStyle}"/>
            </StackPanel>
        </controls:ResponsivePageHost.PageContent>
    </controls:ResponsivePageHost>
</Page>
