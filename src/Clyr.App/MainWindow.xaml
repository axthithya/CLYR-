<Window
    x:Class="Clyr.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CLYR">
    <Grid>
        <NavigationView x:Name="Navigation" PaneTitle="CLYR" IsSettingsVisible="True" SelectionChanged="OnSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Overview" Tag="Overview" />
                <NavigationViewItem Content="Scan" Tag="Scan" />
                <NavigationViewItem Content="Results" Tag="Results" />
                <NavigationViewItem Content="History" Tag="History" />
                <NavigationViewItem Content="Developer Mode" Tag="Developer Mode" />
                <NavigationViewItem Content="Privacy" Tag="Privacy" />
                <NavigationViewItem Content="Licenses" Tag="Licenses" />
                <NavigationViewItem Content="About" Tag="About" />
            </NavigationView.MenuItems>
            <StackPanel Padding="32" Spacing="16">
                <TextBlock Text="CLYR" FontSize="36" FontWeight="SemiBold" />
                <TextBlock Text="Phase 3 analysis and classification are local, metadata-only, and read-only. Findings never authorize cleanup." FontSize="18" TextWrapping="Wrap" />
                <TextBlock x:Name="PageTitle" Text="Overview" FontSize="26" />
                <TextBlock x:Name="PageDescription" Text="Read-only Phase 1 engineering foundation." TextWrapping="Wrap" />
                <TextBlock x:Name="DriveSummaryText" Text="Discovering local drives…" TextWrapping="Wrap" />
                <ComboBox x:Name="DriveSelector" Header="Local volume" MinWidth="620" AutomationProperties.Name="Local volume selector" />
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <RadioButton x:Name="QuickMode" Content="Quick Analysis" GroupName="ScanMode" IsChecked="True" AutomationProperties.HelpText="Faster scan limited to three directory levels." />
                    <RadioButton x:Name="DeepMode" Content="Deep Analysis" GroupName="ScanMode" AutomationProperties.HelpText="Full metadata traversal. It can take substantially longer." />
                </StackPanel>
                <TextBlock Text="Quick is depth-limited. Deep traverses accessible directories. Both skip reparse points, avoid cloud hydration, and report logical size only; hard links may be counted more than once." TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="StartScanButton" Content="Start analysis" Click="OnStartScan" IsEnabled="False" />
                    <Button x:Name="CancelScanButton" Content="Cancel analysis" Click="OnCancelScan" IsEnabled="False" />
                </StackPanel>
                <TextBlock x:Name="ScanStatusText" Text="Not started." FontSize="20" AutomationProperties.LiveSetting="Polite" />
                <TextBlock x:Name="CurrentPathText" Text="No path is being inspected." TextWrapping="Wrap" />
                <TextBlock x:Name="CoverageText" Text="Coverage will appear after analysis." TextWrapping="Wrap" />
                <TextBlock x:Name="RulesStatusText" Text="Checking built-in rule integrity..." TextWrapping="Wrap" />
                <TextBlock Text="Why is this drive full?" FontSize="20" FontWeight="SemiBold" />
                <TextBlock x:Name="ClassificationSummaryText" Text="Classification will appear after analysis." TextWrapping="Wrap" />
                <ListView x:Name="FindingList" MaxHeight="300" AutomationProperties.Name="Classified storage findings" />
                <TextBlock Text="Largest top-level directories" FontSize="20" FontWeight="SemiBold" />
                <ListView x:Name="ResultList" MaxHeight="280" />
                <ListView x:Name="DemoFindings" Visibility="Collapsed" />
            </StackPanel>
        </NavigationView>
    </Grid>
</Window>
