<Window
    x:Class="Clyr.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Clyr.App.Controls"
    Title="CLYR">
    <Grid
        x:Name="ShellRoot"
        MinWidth="{StaticResource ShellMinimumWidth}"
        MinHeight="{StaticResource ShellMinimumHeight}"
        Background="{ThemeResource AppBackground}"
        AutomationProperties.Name="CLYR application shell">
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource TitleBarRowHeight}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- System caption buttons remain native. SetTitleBar makes the rest of
             this non-interactive row a draggable region. -->
        <Grid
            x:Name="AppTitleBar"
            Height="{StaticResource TitleBarHeightValue}"
            Background="{ThemeResource NavigationBackground}"
            ActualThemeChanged="TitleBarThemeChanged"
            SizeChanged="TitleBarSizeChanged"
            AutomationProperties.Name="CLYR title bar">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Margin="19,0,12,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Image
                    Width="18"
                    Height="18"
                    Source="ms-appx:///Assets/Branding/CLYR-AppIcon-Master-1024.png"
                    Stretch="Uniform"
                    AutomationProperties.Name="CLYR application icon" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextPrimary}"
                    Style="{StaticResource ShellTitleTextStyle}"
                    Text="CLYR" />
            </StackPanel>
            <controls:PrivacyBadge
                Grid.Column="2"
                Margin="12,0,8,0"
                VerticalAlignment="Center"
                IsHitTestVisible="False" />
            <Border x:Name="CaptionButtonSpacer" Grid.Column="3" Width="0" />
        </Grid>

        <NavigationView
            x:Name="Navigation"
            Grid.Row="1"
            Background="{ThemeResource NavigationBackground}"
            AlwaysShowHeader="False"
            CompactModeThresholdWidth="{StaticResource NavigationCompactModeThreshold}"
            CompactPaneLength="{StaticResource NavigationPaneCompactWidth}"
            ExpandedModeThresholdWidth="{StaticResource NavigationExpandedModeThreshold}"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="True"
            IsTitleBarAutoPaddingEnabled="False"
            OpenPaneLength="{StaticResource SidebarWidth}"
            PaneDisplayMode="Auto"
            SelectionChanged="OnSelectionChanged"
            AutomationProperties.Name="CLYR navigation"
            AutomationProperties.HelpText="Navigate between CLYR product, advanced, privacy and information pages.">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Overview" Tag="Overview" Style="{StaticResource ShellPrimaryNavigationItemStyle}"
                    ToolTipService.ToolTip="Overview" AutomationProperties.Name="Overview"
                    AutomationProperties.HelpText="View storage clarity and recent analysis status.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE80F;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Scan" Tag="Scan" Style="{StaticResource ShellPrimaryNavigationItemStyle}"
                    ToolTipService.ToolTip="Analyze a drive" AutomationProperties.Name="Scan"
                    AutomationProperties.HelpText="Configure and run a private read-only drive analysis.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE721;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Results" Tag="Results" Style="{StaticResource ShellPrimaryNavigationItemStyle}"
                    ToolTipService.ToolTip="Latest results" AutomationProperties.Name="Results"
                    AutomationProperties.HelpText="Review the latest storage analysis results.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE9D2;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Review Plan" Tag="Review Plan" Style="{StaticResource ShellPrimaryNavigationItemStyle}"
                    ToolTipService.ToolTip="Preview potential actions" AutomationProperties.Name="Review Plan"
                    AutomationProperties.HelpText="Review a dry-run plan before any eligible action.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE9D5;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="History" Tag="History" Style="{StaticResource ShellPrimaryNavigationItemStyle}"
                    ToolTipService.ToolTip="Local history" AutomationProperties.Name="History"
                    AutomationProperties.HelpText="Review local storage analysis history.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE81C;" /></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator AutomationProperties.Name="Advanced navigation separator" />
                <NavigationViewItem
                    Content="Developer Mode" Tag="Developer Mode" Style="{StaticResource ShellNavigationItemStyle}"
                    ToolTipService.ToolTip="Developer Mode" AutomationProperties.Name="Developer Mode"
                    AutomationProperties.HelpText="Inspect supported developer storage tools in read-only mode.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE943;" /></NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator AutomationProperties.Name="Trust and information navigation separator" />
                <NavigationViewItem
                    Content="Privacy" Tag="Privacy" Style="{StaticResource ShellNavigationItemStyle}"
                    ToolTipService.ToolTip="Privacy" AutomationProperties.Name="Privacy"
                    AutomationProperties.HelpText="Read how CLYR keeps analysis private and local.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE72E;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Licenses" Tag="Licenses" Style="{StaticResource ShellNavigationItemStyle}"
                    ToolTipService.ToolTip="Open-source licenses" AutomationProperties.Name="Licenses"
                    AutomationProperties.HelpText="Review CLYR and dependency license information.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE8A5;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="About" Tag="About" Style="{StaticResource ShellNavigationItemStyle}"
                    ToolTipService.ToolTip="About CLYR" AutomationProperties.Name="About"
                    AutomationProperties.HelpText="View CLYR version and capability information.">
                    <NavigationViewItem.Icon><FontIcon FontSize="{StaticResource ShellNavigationIconSize}" Glyph="&#xE946;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Border
                BorderBrush="{ThemeResource BorderSubtle}"
                BorderThickness="1,0,0,0"
                Background="{ThemeResource AppBackground}">
                <ContentControl
                    x:Name="ContentHost"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    AutomationProperties.Name="Current CLYR page" />
            </Border>
        </NavigationView>
    </Grid>
</Window>
