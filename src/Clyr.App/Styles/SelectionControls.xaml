<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="AnalysisModeCardStyle" TargetType="ToggleButton">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="MinHeight" Value="142" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Surface"
                                Background="{ThemeResource SurfacePrimary}"
                                BorderBrush="{ThemeResource BorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CornerRadiusCard}" />
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalContentAlignment="Stretch" />
                        <!-- A checkmark means selection never depends on color alone. -->
                        <Border x:Name="SelectionMark"
                                Width="28"
                                Height="28"
                                Margin="12"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="{ThemeResource AccentPrimary}"
                                CornerRadius="14"
                                Visibility="Collapsed"
                                AutomationProperties.AccessibilityView="Content"
                                AutomationProperties.Name="Selected indicator">
                            <FontIcon
                                FontSize="13"
                                Foreground="{ThemeResource TextOnAccent}"
                                Glyph="&#xE73E;" />
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="Surface.Background" Value="{ThemeResource SurfacePrimary}" />
                                        <Setter Target="Surface.BorderBrush" Value="{ThemeResource BorderSubtle}" />
                                        <Setter Target="Surface.BorderThickness" Value="1" />
                                        <Setter Target="Surface.Opacity" Value="1" />
                                        <Setter Target="SelectionMark.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Surface.Background" Value="{ThemeResource SurfaceHover}" />
                                        <Setter Target="Surface.BorderBrush" Value="{ThemeResource BorderStrong}" />
                                        <Setter Target="Surface.BorderThickness" Value="1" />
                                        <Setter Target="Surface.Opacity" Value="1" />
                                        <Setter Target="SelectionMark.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Surface.Background" Value="{ThemeResource SurfaceSecondary}" />
                                        <Setter Target="Surface.BorderBrush" Value="{ThemeResource BorderStrong}" />
                                        <Setter Target="Surface.BorderThickness" Value="1" />
                                        <Setter Target="Surface.Opacity" Value="0.86" />
                                        <Setter Target="SelectionMark.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Surface.Background" Value="{ThemeResource SurfacePrimary}" />
                                        <Setter Target="Surface.BorderBrush" Value="{ThemeResource BorderSubtle}" />
                                        <Setter Target="Surface.BorderThickness" Value="1" />
                                        <Setter Target="Surface.Opacity" Value="0.58" />
                                        <Setter Target="SelectionMark.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="Surface.Background" Value="{ThemeResource SurfaceSelected}" />
                                        <Setter Target="Surface.BorderBrush" Value="{ThemeResource AccentPrimary}" />
                                        <Setter Target="Surface.BorderThickness" Value="2" />
                                        <Setter Target="Surface.Opacity" Value="1" />
                                        <Setter Target="SelectionMark.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Surface.Background" Value="{ThemeResource SurfaceSelected}" />
                                        <Setter Target="Surface.BorderBrush" Value="{ThemeResource AccentPrimaryHover}" />
                                        <Setter Target="Surface.BorderThickness" Value="2" />
                                        <Setter Target="Surface.Opacity" Value="1" />
                                        <Setter Target="SelectionMark.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="Surface.Background" Value="{ThemeResource SurfaceSelected}" />
                                        <Setter Target="Surface.BorderBrush" Value="{ThemeResource AccentPrimaryPressed}" />
                                        <Setter Target="Surface.BorderThickness" Value="2" />
                                        <Setter Target="Surface.Opacity" Value="0.86" />
                                        <Setter Target="SelectionMark.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CheckedDisabled">
                                    <VisualState.Setters>
                                        <Setter Target="Surface.Background" Value="{ThemeResource SurfaceSelected}" />
                                        <Setter Target="Surface.BorderBrush" Value="{ThemeResource AccentPrimary}" />
                                        <Setter Target="Surface.BorderThickness" Value="2" />
                                        <Setter Target="Surface.Opacity" Value="1" />
                                        <Setter Target="SelectionMark.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
