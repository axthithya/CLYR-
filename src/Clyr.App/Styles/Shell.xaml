<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Keep the native NavigationView template and accessibility behavior, but
         redirect every shell state to the Phase 7.3A semantic palette. -->
    <StaticResource x:Key="NavigationViewDefaultPaneBackground" ResourceKey="NavigationBackground" />
    <StaticResource x:Key="NavigationViewExpandedPaneBackground" ResourceKey="NavigationBackground" />
    <StaticResource x:Key="NavigationViewItemBackground" ResourceKey="NavigationBackground" />
    <StaticResource x:Key="NavigationViewItemBackgroundPointerOver" ResourceKey="SurfaceHover" />
    <StaticResource x:Key="NavigationViewItemBackgroundPressed" ResourceKey="SurfaceSecondary" />
    <StaticResource x:Key="NavigationViewItemBackgroundSelected" ResourceKey="SurfaceSelected" />
    <StaticResource x:Key="NavigationViewItemBackgroundSelectedPointerOver" ResourceKey="SurfaceHover" />
    <StaticResource x:Key="NavigationViewItemBackgroundSelectedPressed" ResourceKey="SurfaceSelected" />
    <StaticResource x:Key="NavigationViewItemForeground" ResourceKey="TextSecondary" />
    <StaticResource x:Key="NavigationViewItemForegroundPointerOver" ResourceKey="TextPrimary" />
    <StaticResource x:Key="NavigationViewItemForegroundPressed" ResourceKey="TextSecondary" />
    <StaticResource x:Key="NavigationViewItemForegroundSelected" ResourceKey="TextPrimary" />
    <StaticResource x:Key="NavigationViewItemForegroundSelectedPointerOver" ResourceKey="TextPrimary" />
    <StaticResource x:Key="NavigationViewItemForegroundSelectedPressed" ResourceKey="TextPrimary" />
    <StaticResource x:Key="NavigationViewSelectionIndicatorForeground" ResourceKey="AccentPrimary" />

    <!-- The native selected indicator is retained and made substantial; the
         selected surface and foreground emphasis are independent signals. -->
    <x:Double x:Key="NavigationViewSelectionIndicatorWidth">4</x:Double>
    <x:Double x:Key="NavigationViewSelectionIndicatorHeight">28</x:Double>

    <Style x:Key="ShellNavigationItemStyle" TargetType="NavigationViewItem">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeightNavigationRow}" />
        <Setter Property="Margin" Value="8,2" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControl}" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>
    <Style x:Key="ShellPrimaryNavigationItemStyle" TargetType="NavigationViewItem" BasedOn="{StaticResource ShellNavigationItemStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="ShellTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyText}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimary}" />
    </Style>
</ResourceDictionary>
