<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="StandardCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfacePrimary}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>
    <Style x:Key="CompactCardStyle" TargetType="Border" BasedOn="{StaticResource StandardCardStyle}">
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>
    <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
        <Setter Property="MinHeight" Value="112" />
    </Style>
    <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource StandardCardStyle}" />

    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceSecondary}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControl}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style x:Key="PrivacyBadgeStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
        <Setter Property="Background" Value="{ThemeResource PrivacySafeSurface}" />
        <Setter Property="BorderBrush" Value="{ThemeResource PrivacySafe}" />
    </Style>
    <Style x:Key="TrustBadgeStyle" TargetType="Border" BasedOn="{StaticResource PrivacyBadgeStyle}" />

    <!-- Native WinUI templates supply pointer, press, disabled, keyboard-focus,
         high-contrast, and 200%-text behavior. These styles only set semantics. -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeightButton}" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
    </Style>
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeightButton}" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
    </Style>
    <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeightButton}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
    </Style>
    <Style x:Key="DestructiveButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeightButton}" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
        <Setter Property="Background" Value="{ThemeResource Error}" />
        <Setter Property="Foreground" Value="{ThemeResource TextOnAccent}" />
    </Style>
    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
        <Setter Property="Width" Value="{StaticResource ControlSizeCompactButton}" />
        <Setter Property="Height" Value="{StaticResource ControlSizeCompactButton}" />
        <Setter Property="MinWidth" Value="{StaticResource ControlSizeCompactButton}" />
        <Setter Property="MinHeight" Value="{StaticResource ControlSizeCompactButton}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
    </Style>
    <Style x:Key="PrimaryActionStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}" />
    <Style x:Key="SecondaryActionStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}" />

    <Style x:Key="InfoBannerStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
        <Setter Property="Background" Value="{ThemeResource InformationSurface}" />
        <Setter Property="BorderBrush" Value="{ThemeResource Information}" />
    </Style>
    <Style x:Key="WarningBannerStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
        <Setter Property="Background" Value="{ThemeResource WarningSurface}" />
        <Setter Property="BorderBrush" Value="{ThemeResource Warning}" />
    </Style>
    <Style x:Key="SuccessBannerStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
        <Setter Property="Background" Value="{ThemeResource SuccessSurface}" />
        <Setter Property="BorderBrush" Value="{ThemeResource Success}" />
    </Style>
    <Style x:Key="DividerStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{ThemeResource BorderSubtle}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
</ResourceDictionary>
